{
  "name": "@guillaume-docquier/oxlint",
  "version": "0.0.0-semantically-released",
  "description": "Shared Oxlint configuration for my TypeScript projects",
  "homepage": "https://github.com/Guillaume-Docquier/oxlint",
  "license": "MIT",
  "author": "Guillaume Docquier",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Guillaume-Docquier/oxlint.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "checks": "pnpm lint:fix && pnpm format:fix && pnpm typecheck && pnpm build",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "lint": "oxlint --max-warnings 0",
    "lint:fix": "pnpm lint --fix",
    "prepack": "pnpm build",
    "prepare": "husky",
    "typecheck": "tsc --project tsconfig.json"
  },
  "devDependencies": {
    "@guillaume-docquier/oxfmt": "^1.0.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "husky": "^9.1.7",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.24.0",
    "semantic-release": "^25.0.5",
    "typescript": "^7.0.2"
  },
  "peerDependencies": {
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.24.0"
  },
  "lint-staged": {
    "*.{md,json,yml,yaml,css,scss}": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.11.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "26.5.0",
      "onFail": "download"
    }
  }
}
